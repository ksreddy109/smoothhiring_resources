{
  "name": "smoothhiring-resources",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "dev:resources": "turbo dev --filter=@smoothhiring/resources",
    "dev:cms": "turbo dev --filter=@smoothhiring/resources-cms",
    "build": "turbo build",
    "build:resources": "turbo build --filter=@smoothhiring/resources",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "verify": "turbo run build type-check lint",
    "verify:static": "node ./tools/verify-static-pages.mjs",
    "verify:hydration": "node ./tools/verify-static-hydration.mjs --base-url http://localhost:3001 --all",
    "deploy:static": "bash ./scripts/deploy-s3.sh",
    "cms:seed": "node ./tools/seed-resources-cms.mjs"
  },
  "devDependencies": {
    "playwright": "^1.60.0",
    "prettier": "^3.3.3",
    "turbo": "^2.3.3"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.33.2"
}
